{
  "name": "lurqrun",
  "version": "0.0.2",
  "description": "A continuously-updated, evidence-scored index of JS/TS frameworks and libraries, exposed as an MCP server, CLI, and agent skill — so AI coding assistants get fresh, objective dependency recommendations.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "jadenryu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jadenryu/lurq.git"
  },
  "homepage": "https://github.com/jadenryu/lurq#readme",
  "bugs": {
    "url": "https://github.com/jadenryu/lurq/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "npm",
    "dependencies",
    "recommendations",
    "claude-code",
    "ai-coding"
  ],
  "bin": {
    "lurq": "dist/bin/lurq.js"
  },
  "workspaces": [
    "apps/*"
  ],
  "files": [
    "dist",
    "src/data/seed.json",
    "templates",
    "drizzle",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin/lurq.ts",
    "lurq": "tsx src/bin/lurq.ts",
    "start": "node dist/bin/lurq.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/bin/lurq.ts db migrate",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "semver": "^7.8.5",
    "update-notifier": "^7.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.5.0",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vitest": "^2.0.5"
  }
}
