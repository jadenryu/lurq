{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "node dist-operator/bin/operator.js worker --once --cap 100 --extract 50",
    "cronSchedule": "*/15 * * * *",
    "restartPolicyType": "NEVER",
    "numReplicas": 1,
    "region": "us-east4-eqdc4a"
  }
}
