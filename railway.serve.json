{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "node dist/bin/lurq.js serve-http",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
