# ── lurq configuration ───────────────────────────────────────────────────
# Copy to `.env` and fill in. Only DATABASE_URL is strictly required to run
# `lurq sync` / `lurq serve`. Everything else degrades gracefully (§15, §17).

# Postgres connection string (must have the `vector` extension available).
# Matches the bundled docker-compose.yml below.
DATABASE_URL=

# GitHub API token — strongly recommended. Without it, GitHub signals
# (stars, issues, release cadence) are skipped and confidence/score drop.
# Create one at https://github.com/settings/tokens (no scopes needed for public data).
GITHUB_TOKEN=

# ── Embeddings (semantic search) ──────────────────────────────────────────
# Provider: "openai" (default) or "local". If "openai" is selected but no
# EMBEDDING_API_KEY is set, lurq automatically falls back to the local
# deterministic embedder so search still works without paid keys.
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Summaries + usage guides (LLM-generated at ingest) ─────────────────────
# Provider: "openai" or "none". With "none" (or no key), lurq falls back to
# the npm description and a category-derived guide — never fabricated.
SUMMARY_PROVIDER=openai
SUMMARY_API_KEY=
SUMMARY_MODEL=gpt-4o-mini

# ── Sandbox verification (optional) ───────────────────────────────────────
# With E2B_API_KEY set, package install + smoke-load runs in an isolated E2B
# cloud microVM (safe for UNTRUSTED packages). Without it, the local
# child-process driver is used — trusted/operator packages only. Get a key at
# https://e2b.dev.
# E2B_API_KEY=
# E2B template to launch; must have node + npm on PATH. Omit for E2B's default;
# pin a Node-versioned template for reproducible runs.
# E2B_TEMPLATE=

# ── Hosted HTTP service (`lurq serve-http`) ───────────────────────────────
# Operator-side only — these belong on YOUR service host, never on a user's
# machine. Users connect to the endpoint with an API key (`lurq install`);
# DATABASE_URL stays server-side. See docs/lurq-hosted-deployment.md.
# Port to listen on (Railway injects PORT automatically).
PORT=8080
# Per-API-key request cap per window, and a coarser per-IP cap (floods).
LURQ_RATE_LIMIT_MAX=120
LURQ_IP_RATE_LIMIT_MAX=240
LURQ_RATE_LIMIT_WINDOW_MS=60000

# ── Client-side (talking to a remote endpoint) ────────────────────────────
# Only needed to point the CLI/wizard at a non-default endpoint or to pre-seed
# the key non-interactively. The wizard writes these into agent config, not here.
# LURQ_ENDPOINT=https://api.lurq.run/mcp
# LURQ_API_KEY=

# ── Caching (optional) ────────────────────────────────────────────────────
# Distributed response cache. With no REDIS_URL, lurq uses an in-process cache
# (the zero-config default; fine for a single instance).
# REDIS_URL=redis://localhost:6379
# Override the on-disk HTTP cache location (default: ~/.cache/lurq/http).
# LURQ_CACHE_DIR=
# TTL in seconds for the response cache.
# LURQ_CACHE_TTL_SEC=

# ── Pre-launch gate (operator only) ───────────────────────────────────────
# When set, lets the owner run CLI commands while the public gate is on. See
# src/core/gate.ts. Leave unset for normal use.
# LURQ_OWNER_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────
# Parallel ingest workers.
LURQ_SYNC_CONCURRENCY=5
# error | warn | info | debug
LOG_LEVEL=info

# Default-sort composite blend λ (§1/§4): composite = (1−λ)·health + λ·quality.
# 0 = pure popularity/health, 1 = pure intrinsic quality. Overridable per-user via
# `lurq edit-weights --set composite.lambda=…`; this env var wins over both.
# LURQ_COMPOSITE_LAMBDA=0.35
