{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node dist-operator/bin/operator.js sync",
    "cronSchedule": "0 6 * * *",
    "restartPolicyType": "NEVER",
    "numReplicas": 1
  }
}
